# ─── ENVIRONMENT VARIABLES ───────────────────────────────────────────────────
# Copy this file to .env.local for local development
# On Vercel: go to Project → Settings → Environment Variables and add these

# Your Groq Cloud API key
GROQ_API_KEY=your-groq-api-key-here
GROQ_MODEL=llama-3.1-8b-versatile

# Optional fallback key for Ollama Cloud
OLLAMA_API_KEY=your-ollama-api-key-here

# ─── VERCEL DEPLOYMENT STEPS ─────────────────────────────────────────────────
# 1. Push this project to GitHub
# 2. Go to https://vercel.com → "Add New Project" → Import from GitHub
# 3. Before deploying: go to Project Settings → Environment Variables
#    Add: GROQ_API_KEY = your-groq-api-key-here
#    Optionally add: OLLAMA_API_KEY = your-ollama-api-key-here
# 4. Deploy → your app is live at https://your-project.vercel.app
